{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron-rebuild",
      "schedule": "0 7 * * 0"
    }
  ],
  "rewrites": [
    {
      "source": "/indexes/:file",
      "destination": "/api/serve-index?file=:file"
    }
  ],
  "functions": {
    "api/cron-rebuild.js": {
      "maxDuration": 300
    }
  }
}
